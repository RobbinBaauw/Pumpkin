\centering
\begin{tabular}{
    |{% for child_heads in headers.values() -%}
        {{ 'c' * child_heads|length }}
        {%- if not loop.last %} | {% endif -%}
    {%- endfor -%}|
}
\hline

\toprule

{% for (parent_head, child_heads) in headers.items() -%}
    \multicolumn{ {{ child_heads | length }} }{ {%- if loop.first -%}|{%- endif -%} c|}{ \textbf{ {{ parent_head }} } }
    {%- if not loop.last -%} & {%- endif -%}
{%- endfor -%} \\

\midrule

{% for child_heads in headers.values() -%}
    {% set outer_loop = loop %}
    {%- for head in child_heads -%}
        \textbf{ {{ head }} }
        {%- if not (loop.last and outer_loop.last) %} & {% endif -%}
    {%- endfor -%}
{%- endfor %} \\

\hline

{% for row in rows %}
    {%- for col in row -%}
        {%- set val = col[0] if col is tuple else col -%}
        {%- set val_format = (val if val is not none else "-") | replace("_", "\_") -%}

        {%- if col is tuple -%}
            {%- if "text-bold" in col[1] -%} \textbf{ {%- endif -%}
            {%- if "color-" in col[1] -%} \textcolor{ {{- col[1].split('-')[1] -}} }{ {%- endif -%}
        {%- endif -%}

        {{ val_format }}

        {%- if col is tuple -%}
            {%- if "text-bold" in col[1] -%} } {%- endif -%}
            {%- if "color-" in col[1] -%} } {%- endif -%}
        {%- endif -%}

        {% if not loop.last %} & {% endif %}
    {%- endfor -%} \\
{% endfor %}

\bottomrule

\end{tabular}

